# StreamFlow Configuration

# Your WhatsApp Support Phone Number (including country code, without '+' or spaces)
# Example: 212600000000
NEXT_PUBLIC_WHATSAPP_NUMBER=212631453486

# Better Auth Configuration
# Base URL is required for auth redirect callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Generate a secure key for production
# BETTER_AUTH_SECRET=

# Database Connection URL (e.g. PostgreSQL)
# DATABASE_URL=
